{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Word": {
      "title": "Word",
      "description": "A vocabulary word to learn",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "word": { "type": "string" },
        "meaning": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "nextReviewDate": { "type": "string", "format": "date-time" },
        "reviewCount": { "type": "number", "description": "Number of successful reviews (0-indexed for Ebbinghaus intervals)" },
        "status": { "type": "string", "enum": ["learning", "graduated"] },
        "lastReviewedAt": { "type": "string", "format": "date-time" },
        "failures": { "type": "array", "items": { "type": "number" }, "description": "Array of reviewCount indices where the user forgot the word" },
        "example": { "type": "string", "description": "An example sentence for the word" },
        "mnemonic": { "type": "string", "description": "Memory hook or root/affix analysis" }
      },
      "required": ["userId", "word", "meaning", "createdAt", "nextReviewDate", "reviewCount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/words/{wordId}": {
      "schema": { "$ref": "#/entities/Word" },
      "description": "Words added by the user"
    }
  }
}
